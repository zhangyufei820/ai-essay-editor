# ============================================
# 沈翔智学 AI Essay Editor - 环境变量配置模板
# ============================================
# 【重要】复制此文件为 .env 并填入实际值
# 不要将 .env 文件提交到 Git！
# ============================================

# ============================================
# 1. Supabase（核心配置）【必填】
# ============================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ============================================
# 2. xunhupay 支付【必填】
# ============================================
XUNHUPAY_APPID=your_appid_here
XUNHUPAY_APPSECRET=your_appsecret_here
XUNHUPAY_API_URL=https://api.xunhupay.com/payment/do.html

# ============================================
# 3. Suno 音乐生成【必填】
# ============================================
SUNO_API_BASE_URL=http://43.154.111.156/v1
SUNO_GENERATE_API_KEY=your_suno_generate_key_here
SUNO_QUERY_API_KEY=your_suno_query_key_here

# ============================================
# 4. Dify AI 服务
# ============================================
# Dify 内部/外部 URL
DIFY_INTERNAL_URL=http://shenxiang-dify-api-1:5001/v1
DIFY_BASE_URL=https://api.shenxiang.school/v1

# Dify API Keys（按模型分类）【必填】
DIFY_API_KEY=your_default_dify_key_here
DIFY_TEACHING_PRO_API_KEY=your_teaching_pro_key_here
DIFY_API_KEY_GPT5=your_gpt5_key_here
DIFY_API_KEY_CLAUDE=your_claude_key_here
DIFY_API_KEY_GEMINI=your_gemini_key_here
DIFY_BANANA_API_KEY=your_banana_key_here

# ============================================
# 5. 作文批改【必填】
# ============================================
ESSAY_CORRECTION_API_KEY=your_essay_correction_key_here
ESSAY_CORRECTION_BASE_URL=https://api.shenxiang.school/v1

# ============================================
# 6. 应用配置
# ============================================
NEXT_PUBLIC_APP_URL=https://www.shenxiang.school
NEXT_PUBLIC_API_BASE_URL=https://api.shenxiang.school
NEXT_PUBLIC_CDN_URL=https://cdn.shenxiang.school

# ============================================
# 7. 腾讯云 COS（支持内外网分离）
# ============================================
# CDN 加速域名（前端读取用）
TENCENT_COS_CDN_DOMAIN=https://cdn.shenxiang.school

# 内网 Endpoint（服务端写/读，避免公网流量）
# 格式: https://<bucket>.cos-internal.<region>.tencentcos.cn
TENCENT_COS_INTERNAL_ENDPOINT=https://media-shenxiang-1394034082.cos-internal.ap-hongkong.tencentcos.cn

# Dify 存储专用 COS Endpoint（与 STORAGE_TYPE=s3 配合使用）
DIFY_STORAGE_ENDPOINT=https://media-shenxiang-1394034082.cos-internal.ap-hongkong.tencentcos.cn

# COS 凭证（永久密钥，不要泄露）
TENCENT_COS_SECRET_ID=your_secret_id_here
TENCENT_COS_SECRET_KEY=your_secret_key_here

# 存储桶配置
TENCENT_COS_BUCKET=media-shenxiang-1394034082
TENCENT_COS_REGION=ap-hongkong

# ============================================
# 8. 短信服务商
# ============================================
SMS_PROVIDER=aliyun

# ============================================
# 9. 邮件服务
# ============================================
RESEND_API_KEY=your_resend_key_here
EMAIL_FROM=noreply@shenxiang.school
